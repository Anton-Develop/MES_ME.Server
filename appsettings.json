{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=192.168.9.64;Database=mesdb;Username=admin;Password=secretpassword;"
  },
  "URLs": "http://*:5000",
  "Jwt": {
    "Key": "verylongsecretkeyforjsonwebtokenforproduction",
    "Issuer": "https://localhost:7000",
    "Audience": "https://localhost:3000",
    "ExpireMinutes": 60
  },
  
    "EPPlus": {
      "ExcelPackage": {
        "License": "NonCommercialOrganization:The noncommercial organization" 
      }
    },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/furnace-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Worker": {
    "HeatingSessionIntervalSeconds": 30,
    "SheetExitGracePeriodMinutes": 2
  },
  "Api": {
    "DefaultPageSize": 500,
    "MaxPageSize": 5000,
    "TemperatureDefaultIntervalMinutes": 1
  },
  "AllowedHosts": "*"
}
