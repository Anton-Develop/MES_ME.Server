{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=192.168.9.64;CommandTimeout=120; Database=mesdb;Username=admin;Password=secretpassword;"
  },
  "URLs": "http://*:5000",
  "Jwt": {
    "Key": "verylongsecretkeyforjsonwebtokenforproduction",
    "Issuer": "https://localhost:7000",
    "Audience": "https://localhost:3000",
    "ExpireMinutes": 60
  },
  
    "EPPlus": {
      "ExcelPackage": {
        "License": "NonCommercialOrganization:The noncommercial organization" 
      }
    },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/furnace-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Worker": {
    "HeatingSessionIntervalSeconds": 30,
    "SheetExitGracePeriodMinutes": 2,
    "CatchUpDays": 7
  },
  "Api": {
    "DefaultPageSize": 500,
    "MaxPageSize": 5000,
    "TemperatureDefaultIntervalMinutes": 1
  },
  "OpcUa": {
  "EndpointUrl": "opc.tcp://192.168.9.1:4840",
  "AnonymousAuth": true,
  "PublishInterval": 1000,
  "SamplingInterval": 2000,
  "Nodes": [
    { "NodeId": "ns=4;s=|var|PLC210 OPC-UA.Application.GenHmiDb.GenHmi.ToHmi.T_F1_MedAct", "Alias": "T_F1_MedAct" },
    { "NodeId": "ns=4;s=|var|PLC210 OPC-UA.Application.GenHmiDb.GenHmi.ToHmi.T_F2_MedAct", "Alias": "T_F2_MedAct" },
    { "NodeId": "ns=4;s=|var|PLC210 OPC-UA.Application.GenHmiDb.GenHmi.ToHmi.T_F3_MedAct", "Alias": "T_F3_MedAct"  },
    { "NodeId": "ns=4;s=|var|PLC210 OPC-UA.Application.GenHmiDb.GenHmi.ToHmi.T_F4_MedAct", "Alias": "T_F4_MedAct"  }
  ]
},
  "AllowedHosts": "*"
}
